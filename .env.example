# ─── LLM (Gemini) ──────────────────────────────────────
GEMINI_API_KEY=AIza...                      # https://aistudio.google.com/app/apikey
GEMINI_CHAT_MODEL=gemini-2.0-flash         # or gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=gemini-embedding-001  # text-embedding-004 is deprecated/404s now
GEMINI_EMBEDDING_DIM=768                     # truncated via output_dimensionality (matches DB column)

# ─── Search (Tavily) ───────────────────────────────────
TAVILY_API_KEY=tvly-...                     # https://app.tavily.com
TAVILY_SEARCH_DEPTH=basic                  # "basic" (faster) | "advanced" (thorough)
TAVILY_MAX_RESULTS=10

# ─── Reranking ─────────────────────────────────────────
COHERE_API_KEY=...                          # https://cohere.com (optional)
COHERE_RERANK_MODEL=rerank-english-v3.0

# ─── Vector DB (PostgreSQL + pgvector) ─────────────────
DATABASE_URL=postgresql+asyncpg://rag:ragpassword@localhost:5432/ragdb
DATABASE_SYNC_URL=postgresql://rag:ragpassword@localhost:5432/ragdb

# ─── Redis (semantic cache) ────────────────────────────
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=3600

# ─── App ───────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
MAX_CONTEXT_CHARS=20000
TOP_K_RETRIEVAL=20
TOP_K_RERANK=8
REFLECTION_ENABLED=true
MULTIHOP_ENABLED=true
